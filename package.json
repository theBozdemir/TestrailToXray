{
  "name": "testrail-to-xray-migration",
  "version": "1.0.0",
  "description": "Migrate test cases, attachments, and historical results from TestRail to Xray (Jira Cloud)",
  "type": "module",
  "scripts": {
    "migrate": "node src/index.js",
    "reimport": "node src/index.js --reimport",
    "dry-run": "node src/index.js --dry-run",
    "audit": "node src/index.js --audit-only",
    "test-testrail": "node src/test-testrail.js",
    "test-xray": "node src/test-xray.js",
    "results-only": "node src/index.js --results-only",
    "repair-descriptions": "node src/index.js --repair-descriptions",
    "fetch-fields": "node src/fetch-testrail-fields.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "form-data": "^4.0.0",
    "p-limit": "^6.1.0"
  }
}
